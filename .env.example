# Copy to `.env` and fill in. Used by `docker compose` (see docker-compose.yml).

# Database (docker-compose Postgres service)
POSTGRES_PASSWORD=bimpass

# Google Gemini — never commit a real key; keep secrets only in `.env` (gitignored).
GEMINI_API_KEY=
# Optional — used by audio/image helpers that still use the OpenAI-compatible Gemini surface
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Optional — native REST base for BIM extraction (`generateContent`). Default is v1beta.
# GEMINI_NATIVE_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Model id for BIM JSON extraction via native `generateContent` (see https://ai.google.dev/gemini-api/docs/models )
# BIM_EXTRACTION_MODEL=gemini-flash-latest

# Host port for nginx (UI + proxied /api). Default 3000 → http://localhost:3000
# WEB_PORT=3000

# Host port for the API container (direct backend in browser). Default 8080 → http://localhost:8080/api/healthz
# API_PORT=8080
