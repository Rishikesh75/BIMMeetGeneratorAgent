# Copy to `.env` and fill in. Used by `docker compose` (see docker-compose.yml).

# Database (docker-compose Postgres service)
POSTGRES_PASSWORD=bimpass

# OpenAI-compatible HTTP API (default: Google Gemini — get a key at https://aistudio.google.com/apikey )
# Never commit a real key; copy this file to `.env` and paste your key there only.
AI_INTEGRATIONS_OPENAI_API_KEY=
# Gemini OpenAI-compatible endpoint (see https://ai.google.dev/gemini-api/docs/openai )
AI_INTEGRATIONS_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Model id for BIM extraction (override if you use OpenAI or another provider)
# BIM_EXTRACTION_MODEL=gemini-2.5-flash

# Host port for nginx (UI + proxied /api). Default 3000 → http://localhost:3000
# WEB_PORT=3000
